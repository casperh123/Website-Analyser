@using WebsiteAnalyzer.Core.Domain
@using WebsiteAnalyzer.Core.Domain.Website
@using WebsiteAnalyzer.Core.Enums
@using WebsiteAnalyzer.Core.Interfaces.Services
@using WebsiteAnalyzer.Web.Components.General.Toggles

@inject IEmailSubcriptionService EmailService;
@inject IScheduleService ScheduleService;

<RadzenCard>
    <RadzenStack>
        <RadzenRow JustifyContent="JustifyContent.SpaceBetween" AlignItems="AlignItems.Center">
            <RadzenText TextStyle="TextStyle.H4">@Website.Name</RadzenText>
            <RadzenStack>
                <ToggleChevron  Open="_open" OpenChanged="ToggleOpen"/>
            </RadzenStack>
        </RadzenRow>

        @if (_open)
        {
            <RadzenStack>
                <RadzenSelectBar @bind-Value="_selectedAction">
                    <Items>
                        @foreach (ScheduledAction action in Actions)
                        {
                            <RadzenSelectBarItem Text="@action.Action.ToDisplayString()" Value="action"></RadzenSelectBarItem>
                        }
                    </Items>
                </RadzenSelectBar>
                <RadzenRow JustifyContent="JustifyContent.Stretch">
                    <RadzenTextBox @bind-Value="@_email" Placeholder="Email" Immediate="true" AutoCompleteType="AutoCompleteType.Email"/>
                    <RadzenButton Click="Subscribe">Add</RadzenButton>
                </RadzenRow>
            </RadzenStack>

            @foreach (EmailSubscription subscription in Subscriptions)
            {
                <RadzenCard>
                    <RadzenRow Gap="20" JustifyContent="JustifyContent.SpaceBetween">
                        <RadzenStack>
                            <RadzenText TextStyle="TextStyle.Subtitle1">Email:</RadzenText>
                            <RadzenText>@subscription.Email</RadzenText>
                        </RadzenStack>
                        <RadzenStack>
                            <RadzenText TextStyle="TextStyle.Subtitle1">Action:</RadzenText>
                            <RadzenText>@GetScheduledAction(subscription.ScheduleActionId).ToDisplayString()</RadzenText>
                        </RadzenStack>
                        <RadzenStack JustifyContent="JustifyContent.Center">
                            <RadzenButton ButtonStyle="ButtonStyle.Danger" Click="@(async () => await Unsubscribe(subscription))">Unsubscribe</RadzenButton>
                        </RadzenStack>
                    </RadzenRow>
                </RadzenCard>
            }
        }
    </RadzenStack>
</RadzenCard>

@code {
    [Parameter, EditorRequired]
    public Website Website { get; set; }

    [Parameter, EditorRequired]
    public IEnumerable<EmailSubscription> Subscriptions { get; set; }= [];
    
    [Parameter, EditorRequired]
    public IEnumerable<ScheduledAction> Actions { get; set; }= [];

    [Parameter, EditorRequired]
    public EventCallback<EmailSubscription> OnSubscribed { get; set; }
    
    [Parameter, EditorRequired]
    public EventCallback<EmailSubscription> OnUnsubscribe { get; set; }
    
    private string _email { get; set; } = "";
    private ScheduledAction _selectedAction { get; set; }
    private bool _open;
    private bool _loaded;

    protected override async Task OnInitializedAsync()
    {
        Subscriptions = await EmailService.GetSubscriptionsByWebsite(Website.Id);
        Actions = await ScheduleService.GetByWebsiteId(Website.Id);
        _selectedAction = Actions.FirstOrDefault();
    }

    private async Task Subscribe()
    {
        EmailSubscription subscription = await EmailService.Subscribe(
            Website.Id,
            _selectedAction.Id,
            _email
        );

        if (OnSubscribed.HasDelegate)
        {
            await OnSubscribed.InvokeAsync(subscription);
        }
        
        _email = "";
    }

    private async Task Unsubscribe(EmailSubscription subscription)
    {
        if (OnUnsubscribe.HasDelegate)
        {
            await OnUnsubscribe.InvokeAsync(subscription);
        }
    }
    
    private async Task ToggleOpen()
    {
        _open = !_open;
    
        if (_open)
        {
            _selectedAction = Actions.FirstOrDefault();
            StateHasChanged();
        }
    }

    private CrawlAction GetScheduledAction(Guid actionId)
    {
        return Actions
            .Where(a => a.WebsiteId == Website.Id)
            .First(a => a.Id == actionId)
            .Action;
    }
}